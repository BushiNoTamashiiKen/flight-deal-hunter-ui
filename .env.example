# Copy to `.env.local` for local development.

# Optional: without this key, POST /api/hunt runs demo mode (canned CPT ⇄ Lisbon stream).
CURSOR_API_KEY=

# Public site URL — used for metadataBase, sitemap, and Open Graph (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://skyflint.example.com

# Set to 1 to disable in-memory rate limiting on POST /api/hunt (not recommended in production).
# SKYFLINT_DISABLE_RATELIMIT=

# Netlify injects COMMIT_REF on builds — do not set manually for deploys.
# COMMIT_REF=
